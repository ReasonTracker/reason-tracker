{
  "name": "@reasontracker/renderer",
  "version": "0.1.0",
  "private": true,
  "description": "Layout core and output adapters for Reason Tracker rendering.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "dependencies": {
    "@reasontracker/contracts": "workspace:*",
    "@reasontracker/engine": "workspace:*",
    "elkjs": "^0.11.1"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "vite-plus": "^0.1.16",
    "vitest": "^2.1.9"
  },
  "scripts": {
    "build": "echo \"Build script pending\"",
    "preview": "tsx ./preview-layout.ts",
    "preview:watch": "node --watch --watch-path=src --watch-path=preview-layout.ts --watch-path=../website/site/css/brand.css --watch-preserve-output --import tsx ./preview-layout.ts",
    "test": "vp test --passWithNoTests"
  }
}
