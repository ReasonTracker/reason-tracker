{
  "name": "reason-tracker",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "00-command-center",
    "app",
    "components",
    "engine",
    "website",
    "videos"
  ],
  "scripts": {
    "developer:install": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-machine.ps1",
    "typecheck": "vp run -r typecheck",
    "maintain:markdown": "vp exec node ./scripts/maintain-markdown.mjs --write-report",
    "website:dev": "vp run -F reason-tracker-repo-website dev",
    "website:build": "vp run -F reason-tracker-repo-website build"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.33.0"
}
