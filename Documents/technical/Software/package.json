{
  "name": "reason-tracker",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "website",
    "contracts",
    "engine",
    "engine-tests",
    "renderer",
    "Video"
  ],
  "scripts": {
    "command-center": "node ./scripts/command-center.mjs",
    "dev:website": "vp run reason-tracker-repo-website#dev",
    "build:website": "vp run reason-tracker-repo-website#build",
    "publish-website": "vp run reason-tracker-repo-website#publish-website",
    "preview": "node ./scripts/preview-live.mjs",
    "video:studio": "pnpm run -F @reasontracker/video studio",
    "video:render": "pnpm run -F @reasontracker/video render",
    "video:render:1": "pnpm run -F @reasontracker/video render:1",
    "video:render:2": "pnpm run -F @reasontracker/video render:2",
    "video:render:episode0001": "pnpm run -F @reasontracker/video render:episode0001",
    "video:render:episode0002": "pnpm run -F @reasontracker/video render:episode0002",
    "test": "vp test",
    "test:all": "vp test",
    "maintain:markdown": "node ./scripts/maintain-markdown.mjs --write-report",
    "test:engine-tests": "vp run -F @reasontracker/engine-tests test",
    "test:engine-tests:watch": "vp run -F @reasontracker/engine-tests test:watch"
  },
  "packageManager": "pnpm@10.33.0"
}