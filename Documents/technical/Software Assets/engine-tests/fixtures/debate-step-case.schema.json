{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reasontracker.dev/schemas/debate-step-case.schema.json",
  "title": "Reason Tracker Debate Step Case",
  "type": "object",
  "required": [
    "id",
    "state",
    "transactions",
    "expect_state",
    "expect_emitted_transactions"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": ["object", "null"]
    },
    "state": {
      "$ref": "#/$defs/debateStepState"
    },
    "transactions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/inputTransaction"
      }
    },
    "expect_state": {
      "$ref": "#/$defs/debateStepState"
    },
    "expect_emitted_transactions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/emittedTransaction"
      }
    }
  },
  "$defs": {
    "debate": {
      "type": "object",
      "required": ["id", "type", "name", "description"],
      "properties": {
        "id": { "type": "string" },
        "type": { "const": "debate" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "mainClaimId": { "type": "string" }
      },
      "additionalProperties": true
    },
    "claim": {
      "type": "object",
      "required": ["id", "type", "content", "pol"],
      "properties": {
        "id": { "type": "string" },
        "type": { "const": "claim" },
        "content": { "type": "string" },
        "pol": { "enum": ["pro", "con"] },
        "forceConfidence": { "type": "number" }
      },
      "additionalProperties": true
    },
    "connector": {
      "type": "object",
      "required": ["id", "type", "source", "target", "proTarget", "affects"],
      "properties": {
        "id": { "type": "string" },
        "type": { "const": "connector" },
        "source": { "type": "string" },
        "target": { "type": "string" },
        "proTarget": { "type": "boolean" },
        "affects": { "enum": ["confidence", "relevance"] }
      },
      "additionalProperties": true
    },
    "score": {
      "type": "object",
      "required": ["id", "type", "confidence", "reversibleConfidence", "relevance"],
      "properties": {
        "id": { "type": "string" },
        "type": { "const": "score" },
        "confidence": { "type": "number" },
        "reversibleConfidence": { "type": "number" },
        "relevance": { "type": "number" }
      },
      "additionalProperties": true
    },
    "debateData": {
      "type": "object",
      "required": ["claims", "connectors"],
      "properties": {
        "claims": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/claim" }
        },
        "connectors": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/connector" }
        }
      },
      "additionalProperties": false
    },
    "debateStepState": {
      "type": "object",
      "required": ["debate", "debateData", "scores"],
      "properties": {
        "debate": { "$ref": "#/$defs/debate" },
        "debateData": { "$ref": "#/$defs/debateData" },
        "scores": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/score" }
        }
      },
      "additionalProperties": false
    },
    "inputTransaction": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "debate"],
          "properties": {
            "kind": { "const": "set-debate" },
            "debate": { "$ref": "#/$defs/debate" }
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["kind", "claim"],
          "properties": {
            "kind": { "const": "set-claim" },
            "claim": { "$ref": "#/$defs/claim" }
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["kind", "claimId"],
          "properties": {
            "kind": { "const": "delete-claim" },
            "claimId": { "type": "string" }
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["kind", "connector"],
          "properties": {
            "kind": { "const": "set-connector" },
            "connector": { "$ref": "#/$defs/connector" }
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["kind", "connectorId"],
          "properties": {
            "kind": { "const": "delete-connector" },
            "connectorId": { "type": "string" }
          },
          "additionalProperties": true
        }
      ]
    },
    "emittedTransaction": {
      "oneOf": [
        { "$ref": "#/$defs/inputTransaction" },
        {
          "type": "object",
          "required": ["kind", "scoreId", "score"],
          "properties": {
            "kind": { "const": "set-score" },
            "scoreId": { "type": "string" },
            "score": { "$ref": "#/$defs/score" }
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["kind", "scoreId"],
          "properties": {
            "kind": { "const": "delete-score" },
            "scoreId": { "type": "string" }
          },
          "additionalProperties": true
        }
      ]
    }
  }
}
